<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_movement_icon_bg"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        tools:cardBackgroundColor="@color/verde_primario"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_movement_type_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            app:tint="@color/blanco"
            android:contentDescription="@null"
            tools:src="@drawable/ic_add" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_movement_quantity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:textColor="@color/texto_principal"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/cv_movement_icon_bg"
        app:layout_constraintEnd_toStartOf="@id/tv_movement_timestamp"
        tools:text="+50 kg" />

    <TextView
        android:id="@+id/tv_movement_concept"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/texto_secundario"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_movement_quantity"
        app:layout_constraintStart_toStartOf="@id/tv_movement_quantity"
        app:layout_constraintEnd_toStartOf="@id/tv_movement_timestamp"
        tools:text="Compra a proveedor Local" />

    <TextView
        android:id="@+id/tv_movement_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/texto_principal"
        android:textSize="15sp"
        android:gravity="end"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Hoy,\n08:30" />

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/borde_tarjeta"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_movement_quantity"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:id="@+id/cv_employee_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/blanco"
    app:strokeColor="@color/borde_tarjeta"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_avatar_container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/siv_employee_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/descripcion_avatar_empleado"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                tools:srcCompat="@android:drawable/sym_def_app_icon"
                android:visibility="visible" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_employee_initials_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/morado_fondo_avatar"
                app:strokeWidth="0dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tv_employee_initials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="@color/texto_principal"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="CJ" />
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_employee_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="@color/texto_principal"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/layout_avatar_container"
            app:layout_constraintBottom_toTopOf="@id/tv_employee_role"
            app:layout_constraintStart_toEndOf="@id/layout_avatar_container"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="María García" />

        <TextView
            android:id="@+id/tv_employee_role"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/texto_secundario"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tv_employee_name"
            app:layout_constraintBottom_toBottomOf="@id/layout_avatar_container"
            app:layout_constraintStart_toStartOf="@id/tv_employee_name"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Cajero" />

        <View
            android:id="@+id/view_card_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/borde_tarjeta"
            app:layout_constraintTop_toBottomOf="@id/layout_avatar_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_access_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_acceso"
            android:textColor="@color/texto_principal"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="@id/switch_access_toggle"
            app:layout_constraintBottom_toBottomOf="@id/switch_access_toggle"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_access_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/view_card_divider"
            app:layout_constraintEnd_toEndOf="parent"
            tools:checked="true" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
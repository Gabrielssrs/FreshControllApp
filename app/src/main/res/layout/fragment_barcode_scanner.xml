<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/texto_principal">

    <androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/layout_header"
    android:layout_width="0dp"
    android:layout_height="64dp"
    android:background="@color/blanco"
    android:elevation="4dp"
    android:paddingHorizontal="12dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/atras"
        android:src="@drawable/ic_arrow_back"
        app:tint="@color/verde_primario"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tv_header_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="@string/escanear_articulo_titulo"
        android:textColor="@color/verde_primario"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Space
        android:id="@+id/space_reticle_bounds"
        android:layout_width="280dp"
        android:layout_height="160dp"
        app:layout_constraintTop_toTopOf="@id/preview_view"
        app:layout_constraintBottom_toBottomOf="@id/preview_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" /> <TextView
        android:id="@+id/tv_scan_instruction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="32dp"
        android:text="@string/instruccion_escaner"
        android:textColor="@color/blanco"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:shadowColor="#80000000"
        android:shadowDx="1"
        android:shadowDy="2"
        android:shadowRadius="4"
        app:layout_constraintBottom_toTopOf="@id/space_reticle_bounds"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/view_corner_top_left_h"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@color/verde_escaner"
        app:layout_constraintTop_toTopOf="@id/space_reticle_bounds"
        app:layout_constraintStart_toStartOf="@id/space_reticle_bounds" />
    <View
        android:id="@+id/view_corner_top_left_v"
        android:layout_width="4dp"
        android:layout_height="32dp"
        android:background="@color/verde_escaner"
        app:layout_constraintTop_toTopOf="@id/space_reticle_bounds"
        app:layout_constraintStart_toStartOf="@id/space_reticle_bounds" />

    <View
        android:id="@+id/view_corner_top_right_h"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@color/verde_escaner"
        app:layout_constraintTop_toTopOf="@id/space_reticle_bounds"
        app:layout_constraintEnd_toEndOf="@id/space_reticle_bounds" />
    <View
        android:id="@+id/view_corner_top_right_v"
        android:layout_width="4dp"
        android:layout_height="32dp"
        android:background="@color/verde_escaner"
        app:layout_constraintTop_toTopOf="@id/space_reticle_bounds"
        app:layout_constraintEnd_toEndOf="@id/space_reticle_bounds" />

    <View
        android:id="@+id/view_corner_bottom_left_h"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@color/verde_escaner"
        app:layout_constraintBottom_toBottomOf="@id/space_reticle_bounds"
        app:layout_constraintStart_toStartOf="@id/space_reticle_bounds" />
    <View
        android:id="@+id/view_corner_bottom_left_v"
        android:layout_width="4dp"
        android:layout_height="32dp"
        android:background="@color/verde_escaner"
        app:layout_constraintBottom_toBottomOf="@id/space_reticle_bounds"
        app:layout_constraintStart_toStartOf="@id/space_reticle_bounds" />

    <View
        android:id="@+id/view_corner_bottom_right_h"
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:background="@color/verde_escaner"
        app:layout_constraintBottom_toBottomOf="@id/space_reticle_bounds"
        app:layout_constraintEnd_toEndOf="@id/space_reticle_bounds" />
    <View
        android:id="@+id/view_corner_bottom_right_v"
        android:layout_width="4dp"
        android:layout_height="32dp"
        android:background="@color/verde_escaner"
        app:layout_constraintBottom_toBottomOf="@id/space_reticle_bounds"
        app:layout_constraintEnd_toEndOf="@id/space_reticle_bounds" />

    <View
        android:id="@+id/view_scan_line"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@color/rojo_escaner"
        android:layout_marginHorizontal="12dp"
        app:layout_constraintTop_toTopOf="@id/space_reticle_bounds"
        app:layout_constraintBottom_toBottomOf="@id/space_reticle_bounds"
        app:layout_constraintStart_toStartOf="@id/space_reticle_bounds"
        app:layout_constraintEnd_toEndOf="@id/space_reticle_bounds" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_bottom_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/fondo_oscuro_semitransparente"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_manual_entry"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/ingresar_codigo_manualmente"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:textColor="@color/blanco"
            app:strokeColor="@color/blanco"
            app:strokeWidth="1.5dp"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>